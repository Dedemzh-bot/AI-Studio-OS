    "docs": {
      "system_summary": "角色私人宿舍系统：玩家通过购买解锁角色专属宿舍，在宿舍内通过点击、滑动等交互方式触发角色动作、语音及小游戏，提升角色好感度，解锁成就与家具互动。",
      "field_dictionary": {
        "dormitory_id": "【整型 Int】宿舍唯一标识ID，自增主键。",
        "character_id": "【整型 Int】角色唯一标识ID，外键关联角色表。",
        "is_purchased": "【布尔 Bool】是否已购买该宿舍，0=未购买，1=已购买。",
        "purchase_price": "【整型 Int】购买宿舍所需货币数量，单位：钻石，不得低于0。",
        "unlock_level": "【整型 Int】解锁该宿舍所需的玩家等级，默认值1。",
        "interaction_type": "【字符串 String】交互类型枚举：'click'=点击，'slide'=滑动，'drag'=拖拽。",
        "target_body_part": "【字符串 String】交互目标身体部位，如'head','arm','leg'，用于动作触发。",
        "target_furniture_id": "【整型 Int】交互目标家具ID，外键关联家具表，0表示无家具。",
        "slide_direction": "【字符串 String】滑动方向枚举：'up','down','left','right'，仅当interaction_type='slide'时有效。",
        "is_valid": "【布尔 Bool】该交互组合是否有效，0=无效，1=有效。",
        "minigame_id": "【整型 Int】小游戏唯一标识ID。",
        "minigame_type": "【字符串 String】小游戏类型枚举：'puzzle','rhythm','memory'。",
        "is_active": "【布尔 Bool】小游戏是否处于激活状态，0=未激活，1=激活。",
        "current_score": "【整型 Int】小游戏当前得分，初始值0。",
        "target_score": "【整型 Int】小游戏通关目标分数，不得低于0。",
        "remaining_time": "【整型 Int】小游戏剩余时间（秒），初始值由配置决定。",
        "is_victory": "【布尔 Bool】小游戏是否胜利，0=失败，1=胜利。",
        "total_affection": "【整型 Int】角色累计总好感度，初始值0。",
        "daily_affection_gained": "【整型 Int】当日已获得好感度，每日重置为0。",
        "daily_affection_limit": "【整型 Int】每日好感度获取上限，默认值100。",
        "last_interaction_date": "【整型 Int】上次交互日期（Unix时间戳），用于计算每日重置。",
        "achievement_id": "【整型 Int】成就唯一标识ID。",
        "achievement_name": "【字符串 String】成就名称，用于UI显示。",
        "is_unlocked": "【布尔 Bool】成就是否已解锁，0=未解锁，1=已解锁。",
        "unlock_condition_type": "【字符串 String】解锁条件类型枚举：'affection'=好感度，'minigame'=小游戏，'interaction'=交互次数。",
        "unlock_condition_value": "【整型 Int】解锁条件的目标值，如好感度达到500。",
        "current_progress": "【整型 Int】当前进度值，用于条件判断。",
        "furniture_id": "【整型 Int】家具唯一标识ID。",
        "furniture_name": "【字符串 String】家具名称，用于UI显示。",
        "interaction_zone": "【字符串 String】家具交互区域坐标或区域标识，如'bed_center','chair_seat'。",
        "drag_to_count": "【整型 Int】拖拽到该家具所需次数，用于触发动作。",
        "associated_action_id": "【整型 Int】关联的动作ID，外键关联动作表。"
      },
      "relations_and_enums": {
        "dormitory_id": "外键 → dormitory_purchase.dormitory_id，唯一标识宿舍。",
        "character_id": "外键 → character_config.character_id，关联角色数据。",
        "target_furniture_id": "外键 → furniture.furniture_id，标识交互目标家具。",
        "associated_action_id": "外键 → action_config.action_id，触发特定动作。",
        "interaction_type": "枚举值：'click'=点击，'slide'=滑动，'drag'=拖拽。",
        "slide_direction": "枚举值：'up'=上滑，'down'=下滑，'left'=左滑，'right'=右滑。",
        "minigame_type": "枚举值：'puzzle'=拼图，'rhythm'=节奏，'memory'=记忆。",
        "unlock_condition_type": "枚举值：'affection'=好感度，'minigame'=小游戏，'interaction'=交互次数。",
        "is_purchased": "枚举值：0=未购买，1=已购买。",
        "is_valid": "枚举值：0=无效交互，1=有效交互。",
        "is_active": "枚举值：0=未激活，1=激活。",
        "is_victory": "枚举值：0=失败，1=胜利。",
        "is_unlocked": "枚举值：0=未解锁，1=已解锁。"
      },
      "implementation_notes": "1. 每日好感度重置建议在服务器每日凌晨4点进行，基于last_interaction_date判断。2. 交互检测模块需实时监听玩家点击/滑动事件，结合target_body_part和target_furniture_id进行有效性校验。3. 小游戏激活后，使用remaining_time倒计时，超时自动判定失败。4. 成就系统采用进度监听模式，当current_progress达到unlock_condition_value时自动解锁。5. 家具的drag_to_count用于累加拖拽次数，达到阈值后触发associated_action_id对应的动作。6. 所有交互动作需预加载语音和动画资源，避免卡顿。"
    },
