  "payload": {
    "docs": {
      "system_summary": "【角色私人宿舍】系统是一个一次性付费解锁的高级内容包，通过自由观赏、互动、擦边小游戏与好感度累积，强化玩家与五星角色之间的情感羁绊，并驱动皮肤与限定内容的商业化变现。",
      "field_dictionary": {
        "dormitory_unlocked": "【布尔型】标识玩家是否已购买并永久解锁宿舍系统。true=已解锁，false=未解锁。默认值：false。",
        "is_dormitory_unlocked": "【布尔型】接口返回字段，用于前端判断宿舍入口是否可点击。true=可进入，false=隐藏或置灰。默认值：false。",
        "unlock_dormitory": "【布尔型】接口调用字段，触发永久解锁操作。仅当支付成功且dormitory_unlocked为false时有效。默认值：false。",
        "dormitory_affection": "【整数型】每个五星角色独立的宿舍好感度值，范围0-1000。每1点对应好感度等级Lv.1-Lv.10的进度。默认值：0。",
        "get_dormitory_affection": "【整数型】接口返回字段，返回指定角色的dormitory_affection当前值。默认值：0。",
        "add_dormitory_affection": "【整数型】接口调用字段，传入要增加的好感度数值。范围：1-50。默认值：0。",
        "unlocked_interactions": "【数组型】存储已解锁的互动动作ID列表，每个ID为字符串格式（如\"interact_head_rub_01\"）。默认值：[]。",
        "unlocked_voice_lines": "【数组型】存储已解锁的宿舍专属语音ID列表，每个ID为字符串格式（如\"voice_dorm_head_rub_01\"）。默认值：[]。",
        "get_dormitory_interaction_list": "【数组型】接口返回字段，根据角色ID和当前好感度等级，返回可触发的互动动作与语音ID的配对列表。每个元素为对象：{interaction_id: string, voice_id: string}。默认值：[]。",
        "interaction_cooldown": "【浮点型】互动冷却时间，单位秒。范围：0.0-5.0。默认值：5.0。",
        "unlocked_skins": "【数组型】存储玩家已解锁的角色皮肤ID列表，每个ID为字符串格式（如\"skin_swimsuit_01\"）。默认值：[]。",
        "minigame_weekly_reset": "【布尔型】标识本周小游戏是否已进行。true=已进行，false=未进行。每周一凌晨4点重置为false。默认值：false。",
        "minigame_result": "【字符串型】小游戏对局结果。枚举值：\"win\"（胜利）、\"lose\"（失败）、\"disconnect\"（断线）。默认值：\"lose\"。",
        "dormitory_voice_pool": "【数组型】存储所有宿舍专属语音资源的ID列表，按好感度等级分组。每个元素为对象：{affection_level: int, voice_ids: [string]}。默认值：[]。"
      },
      "relations_and_enums": {
        "跨表外键调用关系": {
          "dormitory_affection": "关联角色表（role_id），每个角色独立存储好感度值。",
          "unlocked_interactions": "关联互动动作配置表（interaction_id），通过好感度等级解锁。",
          "unlocked_voice_lines": "关联语音资源表（voice_id），通过好感度等级解锁。",
          "unlocked_skins": "关联皮肤表（skin_id），与主系统皮肤数据共享。",
          "get_dormitory_interaction_list": "依赖dormitory_affection计算当前等级，再查询unlocked_interactions和unlocked_voice_lines。",
          "minigame_weekly_reset": "依赖全局时间系统，每周一凌晨4点触发重置。"
        },
        "状态码枚举": {
