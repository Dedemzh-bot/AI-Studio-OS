{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GuildTechTreeSystem",
  "description": "公会科技树系统数据结构，包含科技树、节点、升级记录及严格的因果追踪。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "guild_id",
    "tech_tree_version",
    "nodes",
    "currency_log",
    "trigger_trace"
  ],
  "properties": {
    "guild_id": {
      "type": "string",
      "description": "公会唯一标识符。",
      "minLength": 1,
      "maxLength": 64
    },
    "tech_tree_version": {
      "type": "integer",
      "description": "科技树版本号，用于处理版本更新时的数据迁移。",
      "minimum": 1
    },
    "nodes": {
      "type": "object",
      "description": "科技树节点状态映射，key为节点ID，value为节点状态。",
      "additionalProperties": false,
      "patternProperties": {
        "^tech_node_[a-zA-Z0-9_]+$": {
          "type": "object",
          "description": "单个科技树节点的状态。",
          "additionalProperties": false,
          "required": [
            "node_id",
            "current_level",
            "is_unlocked",
            "unlock_timestamp",
            "last_upgrade_timestamp"
          ],
          "properties": {
            "node_id": {
              "type": "string",
              "description": "节点ID，与key保持一致。",
              "pattern": "^tech_node_[a-zA-Z0-9_]+$"
            },
            "current_level": {
              "type": "integer",
              "description": "当前等级，0表示未解锁。",
              "minimum": 0,
              "maximum": 10
            },
            "is_unlocked": {
              "type": "boolean",
              "description": "是否已解锁。"
            },
            "unlock_timestamp": {
              "type": "integer",
              "description": "解锁时的Unix时间戳（秒）。",
              "minimum": 0
            },
            "last_upgrade_timestamp": {
              "type": "integer",
              "description": "最后升级时的Unix时间戳（秒）。",
              "minimum": 0
            }
          }
        }
      },
      "minProperties": 1
    },
    "currency_log": {
      "type": "array",
      "description": "公会货币消耗日志，用于审计和回滚。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "log_id",
          "node_id",
          "action_type",
          "cost_amount",
          "cost_timestamp",
          "trigger_source"
        ],
        "properties": {
          "log_id": {
            "type": "string",
            "description": "日志唯一ID，用于防重复。",
            "pattern": "^currency_log_[a-f0-9]{32}$"
          },
          "node_id": {
            "type": "string",
            "description": "被操作的节点ID。",
            "pattern": "^tech_node_[a-zA-Z0-9_]+$"
          },
          "action_type": {
            "type": "string",
            "description": "操作类型：'unlock' 或 'upgrade'。",
            "enum": [
              "unlock",
              "upgrade"
            ]
          },
          "cost_amount": {
            "type": "integer",
            "description": "消耗的公会货币数量。",
            "minimum": 1,
            "maximum": 1000
          },
          "cost_timestamp": {
            "type": "integer",
            "description": "消耗发生的Unix时间戳（秒）。",
            "minimum": 0
          },
          "trigger_source": {
            "type": "string",
            "description": "触发此消耗的来源追踪标签，用于防范漏洞。格式：'guild_<guild_id>_member_<member_id>_<action>'",
            "pattern": "^guild_[a-zA-Z0-9]+_member_[a-zA-Z0-9]+_(unlock|upgrade)$"
          }
        }
      },
      "uniqueItems": true
    },
    "trigger_trace": {
      "type": "object",
      "description": "全局触发来源追踪标签，用于记录本次数据变更的最终来源。",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_id",
        "action",
        "timestamp"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "description": "触发来源类型。",
          "enum": [
            "guild_member",
            "system",
            "admin_tool"
          ]
        },
        "source_id": {
          "type": "string",
          "description": "触发来源的具体ID（如成员ID、管理员ID）。",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "description": "触发的具体动作。",
          "enum": [
            "unlock_node",
            "upgrade_node",
            "system_reset",
            "admin_modify"
          ]
        },
        "timestamp": {
          "type": "integer",
          "description": "触发时的Unix时间戳（秒）。",
          "minimum": 0
        }
      }
    }
  }
}