{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FrostNovaSkill",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_id",
    "skill_name",
    "description",
    "base_damage",
    "freeze_duration",
    "radius",
    "trigger_source"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^sk_[a-z]+_[a-z_]+$",
      "description": "技能唯一标识，必须符合 sk_属性_名称 格式，例如 sk_ice_frost_nova"
    },
    "skill_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "技能显示名称，例如 冰霜新星"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "技能描述文本，例如 以自身为中心释放冰霜冲击波，冻结周围敌人"
    },
    "base_damage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "初始基础伤害值，范围 0-100，防止破坏前期体验"
    },
    "freeze_duration": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "冻结持续时间，单位为秒，范围 0-10"
    },
    "radius": {
      "type": "number",
      "minimum": 0,
      "maximum": 500,
      "description": "技能影响范围半径，单位为游戏单位，范围 0-500"
    },
    "trigger_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id",
        "position",
        "timestamp"
      ],
      "properties": {
        "entity_id": {
          "type": "string",
          "minLength": 1,
          "description": "触发技能的实体唯一标识，例如 Mage_012"
        },
        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "z"
          ],
          "properties": {
            "x": {
              "type": "number",
              "description": "触发位置 X 坐标"
            },
            "y": {
              "type": "number",
              "description": "触发位置 Y 坐标"
            },
            "z": {
              "type": "number",
              "description": "触发位置 Z 坐标"
            }
          },
          "description": "技能释放时的三维坐标"
        },
        "timestamp": {
          "type": "number",
          "minimum": 0,
          "description": "技能触发时的 Unix 时间戳（秒）"
        }
      },
      "description": "技能触发来源追踪，用于因果追踪与防漏洞（如地图边缘爆炸导致无限刷怪）"
    }
  }
}